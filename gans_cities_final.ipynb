   "source": [
    "import random\n",
    "\n",
    "def generate_mock_flights(icao, n=5):\n",
    "    airlines = ['LH', 'FR', 'EW', 'AF', 'KL']\n",
    "    airports = ['EDDF', 'EDDM', 'LFPG', 'EHAM', 'LOWW']\n",
    "\n",
    "    flights = []\n",
    "\n",
    "    for i in range(n):\n",
    "        flights.append({\n",
    "            'flight_num':     f\"{random.choice(airlines)}{random.randint(100,999)}\",\n",
    "            'departure_icao': random.choice(airports),\n",
    "            'arrival_icao':   icao,\n",
    "            'arrival_time':   (datetime.now() + timedelta(hours=random.randint(1,12))).isoformat()\n",
    "        })\n",
    "\n",
    "    return flights"
   ]
  },
