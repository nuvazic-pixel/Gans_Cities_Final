   "source": [
    "## 10. Fetch Airports + Flights (AeroDataBox)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 70,
   "id": "189be30b",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_flights(icao, city_name):\n",
    "    tomorrow  = (datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d')\n",
    "    time_from = f'{tomorrow}T00:00'\n",
    "    time_to   = f'{tomorrow}T11:59'   # FIX 12h limit\n",
    "\n",
    "    url = f'https://aerodatabox.p.rapidapi.com/flights/airports/icao/{icao}/{time_from}/{time_to}'\n",
    "\n",
    "    params = {\n",
    "        'withLeg':        'true',\n",
    "        'direction':      'Arrival',\n",
    "        'withCancelled':  'false',\n",
    "        'withCodeshared': 'false',\n",
    "        'withCargo':      'false',\n",
    "        'withPrivate':    'false',\n",
    "    }\n",
    "\n",
    "    try:\n",
    "        r = requests.get(url, headers=AERO_HEADERS, params=params, timeout=10)\n",
    "\n",
    "        # DEBUG (poți comenta după)\n",
    "        print(f'\\nDEBUG {icao} STATUS: {r.status_code}')\n",
    "\n",
    "        # 🔴 RATE LIMIT / ERROR → FALLBACK\n",
    "        if r.status_code != 200:\n",
    "            print(f'  ⏳ API failed → using MOCK for {icao}')\n",
    "            return generate_mock_flights(icao)\n",
    "\n",
    "        arrivals = r.json().get('arrivals', [])\n",
    "\n",
    "        # 🔴 EMPTY → fallback\n",
    "        if not arrivals:\n",
    "            print(f'  ⚠️ Empty API → using MOCK for {icao}')\n",
    "            return generate_mock_flights(icao)\n",
    "\n",
    "        flights = []\n",
    "        for flight in arrivals:\n",
    "            flights.append({\n",
    "                'flight_num':     flight.get('number', ''),\n",
    "                'departure_icao': flight.get('departure', {}).get('airport', {}).get('icao', ''),\n",
    "                'arrival_icao':   icao,\n",
    "                'arrival_time':   flight.get('arrival', {}).get('scheduledTime', {}).get('local', ''),\n",
    "            })\n",
    "\n",
    "        return flights\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'  ⚠️ Exception → MOCK {icao}: {e}')\n",
    "        return generate_mock_flights(icao)\n",
    "\n",
    "\n",
    "\n",
    "\n"
   ]
  },
  {
