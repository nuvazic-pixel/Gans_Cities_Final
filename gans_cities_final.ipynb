   "source": [
    "## 5. Weather Functions (OWM + Open-Meteo)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 48,
   "id": "92bd2004",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Weather function updated ✅\n"
     ]
    }
   ],
   "source": [
    "def get_owm_forecast(lat, lon, city_name):\n",
    "    if lat is None or lon is None:\n",
    "        return []\n",
    "    params = {\n",
    "        'lat':   lat,\n",
    "        'lon':   lon,\n",
    "        'appid': OWM_API_KEY,\n",
    "        'units': 'metric',\n",
    "        'lang':  'en',\n",
    "        'cnt':   40\n",
    "    }\n",
    "    try:\n",
    "        r = requests.get('https://api.openweathermap.org/data/2.5/forecast',\n",
    "                         params=params, timeout=10)\n",
    "        if r.status_code != 200:\n",
    "            print(f'  ⚠️  OWM {r.status_code} for {city_name}')\n",
    "            return []\n",
    "\n",
    "        forecast_list = []\n",
    "        for forecast in r.json()['list']:\n",
    "            forecast_dict = {\n",
    "                'forecast_time': forecast.get('dt_txt'),\n",
    "                'temperature':   forecast.get('main', {}).get('temp'),\n",
    "                'feels_like':    forecast.get('main', {}).get('feels_like'),\n",
    "                'outlook':       forecast.get('weather', [{}])[0].get('main'),\n",
    "                'wind_speed':    forecast.get('wind', {}).get('speed', 0),\n",
    "                'rain':          forecast.get('rain', {}).get('3h', 0),   # ← niet altijd aanwezig\n",
    "                'snow':          forecast.get('snow', {}).get('3h', 0),   # ← niet altijd aanwezig\n",
    "                'rain_prob':     forecast.get('pop', 0),\n",
    "            }\n",
    "            forecast_list.append(forecast_dict)\n",
    "\n",
    "        return forecast_list\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'  ⚠️  OWM error {city_name}: {e}')\n",
    "        return []\n",
    "\n",
    "print('Weather function updated ✅')\n"
   ]
  },
