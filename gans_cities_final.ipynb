    "cities_rows  = []\n",
    "city_id      = 1\n",
    "\n",
    "for city_name, wiki_slug, country_code in CITIES_META:\n",
    "    print(f'Scraping {city_name}...', end=' ')\n",
    "    try:\n",
    "        soup    = get_soup(wiki_slug)\n",
