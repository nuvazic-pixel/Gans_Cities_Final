    "# Airports per city\n",
    "query = '''\n",
    "    SELECT\n",
    "        c.city_name,\n",
    "        a.airport_icao,\n",
    "        a.airport_name\n",
    "    FROM cities_airports ca\n",
    "    JOIN cities   c ON ca.city_id      = c.city_id\n",
    "    JOIN airports a ON ca.airport_icao = a.airport_icao\n",
    "    ORDER BY c.city_name\n",
    "'''\n",
    "pd.read_sql(query, engine)"
   ]
  },
